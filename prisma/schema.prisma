generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  createdAt        DateTime @default(now())
  bankrollStart    Float    @default(0)
  bankrollCurrent  Float    @default(0)
  bets             Bet[]
}

model Team {
  id             String               @id @default(uuid())
  externalId     String               @unique
  name           String
  shortName      String?
  logo           String?
  leagueCode     String?
  homeMatches    Match[]              @relation("HomeTeam")
  awayMatches    Match[]              @relation("AwayTeam")
  weightOverride TeamWeightOverride?
}

model Match {
  id            String      @id @default(uuid())
  externalId    String      @unique
  homeTeamId    String
  awayTeamId    String
  homeTeam      Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  league        String
  leagueCode    String
  matchDate     DateTime
  status        MatchStatus @default(SCHEDULED)
  homeScore     Int?
  awayScore     Int?
  homeOdds      Float?
  drawOdds      Float?
  awayOdds      Float?
  stats         Json?
  rawOddsCache  Json?
  oddsUpdatedAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  picks         Pick[]
}

model Pick {
  id               String       @id @default(uuid())
  matchId          String
  match            Match        @relation(fields: [matchId], references: [id])
  market           String
  selection        String
  odds             Float
  americanOdds     Int
  confidenceScore  Float
  reasoning        String       @db.Text
  sentimentSummary String?      @db.Text
  status           PickStatus   @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  bets             Bet[]
  learningLog      LearningLog?
}

model Bet {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  pickId    String
  pick      Pick      @relation(fields: [pickId], references: [id])
  stake     Float
  odds      Float
  result    BetResult @default(PENDING)
  profit    Float?
  notes     String?
  createdAt DateTime  @default(now())
  settledAt DateTime?
}

model Log {
  id        String   @id @default(uuid())
  type      String
  message   String   @db.Text
  meta      Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

/**
 * Post-mortem analysis generated when a pick is marked LOST.
 * Captures what went wrong and feeds into future scoring adjustments.
 */
model LearningLog {
  id           String   @id @default(uuid())
  pickId       String   @unique
  pick         Pick     @relation(fields: [pickId], references: [id])
  // Human-readable explanation of what happened
  whatHappened String   @db.Text
  // Which factors were the main cause: { form: bool, h2h: bool, oddsValue: bool, homeAdvantage: bool }
  wrongFactors Json
  // Recommended weight deltas: { formDelta: -0.05, h2hDelta: +0.05, ... }
  adjustments  Json
  createdAt    DateTime @default(now())
}

/**
 * Team-specific scoring weight overrides.
 * Built up over time from LearningLog recommendations.
 * If a team consistently beats our model, we adjust weights for future picks.
 */
model TeamWeightOverride {
  id        String   @id @default(uuid())
  teamId    String   @unique
  team      Team     @relation(fields: [teamId], references: [id])
  // Overrides merged on top of global weights: { formWeight: 0.3, h2hWeight: 0.25, ... }
  weights   Json
  updatedAt DateTime @updatedAt
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum PickStatus {
  PENDING
  WON
  LOST
  VOID
  SKIPPED
}

enum BetResult {
  PENDING
  WON
  LOST
  VOID
}
